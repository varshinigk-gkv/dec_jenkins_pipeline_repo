pipeline {
    agent any

    parameters {
        booleanParam(name: 'DEPLOY', description: 'want to deploy to Production')

    }
    
    environment {
        CURRENT_ENV = 'prod'
    }

      stages {
        stage('STAGE1 When Branch main') {
            when {
                branch 'main'
            }
            steps {
                echo "This is the FINAL stage" 
                 sh '''
                    sleep 5
                    exit 1
                '''
            }
        }

        stage('when environment') {
            when {
                environment name: 'CURRENT_ENV', value: 'prod'
            }
            steps {
                echo "This is the FINAL stage" 
                 sh 'sleep 5'
            }
        }
        stage('when parameter') {
            when {
                allOf{
                    branch 'main'
                    expression { params.DEPLOY == true}

                }
                
            }
            steps {
                echo "This is the FINAL stage" 
                 sh 'sleep 5'
            }
        }
      }
}